<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+) override:
         Set background to brand-blue and icon to fully transparent
         so the OS splash shows only a plain blue screen that blends
         seamlessly into our Flutter SplashScreen. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/ic_launcher_background</item>
        <!-- Transparent icon = no icon visible, just the blue background -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/ic_launcher_background</item>
    </style>
</resources>
